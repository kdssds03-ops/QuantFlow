# ──────────────────────────────────────────────
# QuantFlow - Environment Variables (TEMPLATE)
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

APP_NAME=QuantFlow
APP_ENV=development
DEBUG=true
SECRET_KEY=
TZ=Asia/Seoul

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=quantflow
POSTGRES_PASSWORD=
POSTGRES_DB=quantflow
DATABASE_URL=postgresql+asyncpg://quantflow:<PASSWORD>@postgres:5432/quantflow

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://redis:6379/0

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=
EXCHANGE_NAME=binance

LOG_LEVEL=INFO
